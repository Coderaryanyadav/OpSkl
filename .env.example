# OpSkl Monorepo Environment Variables Example
# Duplicate this file as .env in the respective sub-apps and fill in actual credentials.

# 1. Supabase Connection Parameters
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 2. payment Webhooks & Gateways
RAZORPAY_KEY_ID=rzp_test_yourkeyid
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_signature_secret

# 3. AI Orchestrator Parameters
GEMINI_API_KEY=your_gemini_api_key
